#!/usr/bin/env bash
# suit-manager.sh
# suit Manager (hardened, no feature removal)
# Version: 3.0.1
set -Eeuo pipefail
IFS=$'\n\t'

APP_NAME="suit"
BIN_NAME="suit-tunnel"
SERVICE_PREFIX="suittunnel"

INSTALL_DIR="/opt/suittunnel"
CONFIG_DIR="/etc/suittunnel"
STATE_DIR="/var/lib/suittunnel"
LOG_DIR="/var/log/suittunnel"
SYSTEMD_DIR="/etc/systemd/system"

BIN_PATH="${INSTALL_DIR}/${BIN_NAME}"
VERSION_FILE="${INSTALL_DIR}/VERSION"

REPO_OWNER="devprogrmer"
REPO_NAME="suitspoof"
GITHUB_API="https://api.github.com/repos/${REPO_OWNER}/${REPO_NAME}/releases/latest"

BOLD='\033[1m'; DIM='\033[2m'
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; RESET='\033[0m'

info(){ echo -e "${CYAN}[INFO]${RESET}  $*"; }
ok(){ echo -e "${GREEN}[OK]${RESET}    $*"; }
warn(){ echo -e "${YELLOW}[WARN]${RESET}  $*"; }
err(){ echo -e "${RED}[ERROR]${RESET} $*" >&2; }
die(){ err "$*"; exit 1; }

on_err() {
  local exit_code=$?
  err "Command failed (exit=${exit_code}) at line ${BASH_LINENO[0]}: ${BASH_COMMAND}"
  exit "${exit_code}"
}
trap on_err ERR

require_root(){ [[ "${EUID}" -eq 0 ]] || die "Run as root."; }

need_cmd(){
  local c
  for c in "$@"; do
    command -v "$c" >/dev/null 2>&1 || die "Missing dependency: $c"
  done
}

ensure_dirs(){
  mkdir -p "${INSTALL_DIR}" "${CONFIG_DIR}" "${STATE_DIR}" "${LOG_DIR}"
  chmod 750 "${CONFIG_DIR}" || true
}

random_hex(){
  local n="${1:-32}"
  head -c "${n}" /dev/urandom | xxd -p -c "${n}"
}

ask(){
  local __var="$1" __prompt="$2" __default="${3:-}" __val
  if [[ -n "${__default}" ]]; then
    read -r -p "${__prompt} [${__default}]: " __val
    __val="${__val:-${__default}}"
  else
    read -r -p "${__prompt}: " __val
  fi
  printf -v "${__var}" "%s" "${__val}"
}

ask_bool(){
  local __var="$1" __prompt="$2" __default="${3:-n}" __ans
  while true; do
    read -r -p "${__prompt} [y/n,${__default}]: " __ans
    __ans="${__ans:-${__default}}"
    case "${__ans,,}" in
      y|yes) printf -v "${__var}" "true"; return ;;
      n|no)  printf -v "${__var}" "false"; return ;;
      *) echo "Please enter y or n." ;;
    esac
  done
}

validate_ip(){
  local ip="$1"
  [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || return 1
  IFS='.' read -r o1 o2 o3 o4 <<< "$ip"
  for o in "$o1" "$o2" "$o3" "$o4"; do
    ((o >= 0 && o <= 255)) || return 1
  done
  return 0
}

validate_port(){
  local p="$1"
  [[ "$p" =~ ^[0-9]+$ ]] || return 1
  ((p >= 1 && p <= 65535))
}

get_latest_version(){
  curl -fsSL "${GITHUB_API}" | grep -m1 '"tag_name"' | sed -E 's/.*"([^"]+)".*/\1/'
}

get_download_url(){
  local j
  j="$(curl -fsSL "${GITHUB_API}")"
  echo "${j}" \
    | grep '"browser_download_url"' \
    | sed -E 's/.*"([^"]+)".*/\1/' \
    | grep -Ei 'linux.*(x86_64|amd64)|suit-tunnel|suitspoof|suit' \
    | head -n1
}

ensure_service_template(){
  local unit="${SYSTEMD_DIR}/${SERVICE_PREFIX}@.service"
  if [[ -f "${unit}" ]]; then
    return
  fi

  cat > "${unit}" <<EOF
[Unit]
Description=${APP_NAME} instance %i
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
ExecStart=${BIN_PATH} --config ${CONFIG_DIR}/%i.toml
WorkingDirectory=${INSTALL_DIR}
Restart=on-failure
RestartSec=2
LimitNOFILE=1048576
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_RAW
CapabilityBoundingSet=CAP_NET_ADMIN CAP_NET_RAW
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
EOF

  systemctl daemon-reload
  ok "Created ${SERVICE_PREFIX}@.service"
}

cmd_download(){
  require_root
  need_cmd curl sed grep head chmod mv ln mktemp
  ensure_dirs

  local ver url tmp
  ver="$(get_latest_version || true)"
  url="$(get_download_url || true)"
  [[ -n "${url}" ]] || die "Could not detect release asset URL from GitHub API."

  tmp="$(mktemp)"
  info "Downloading binary..."
  curl -fL --progress-bar -o "${tmp}" "${url}"
  chmod +x "${tmp}"
  mv "${tmp}" "${BIN_PATH}"
  ln -sf "${BIN_PATH}" "/usr/local/bin/${BIN_NAME}"

  [[ -n "${ver}" ]] && echo "${ver}" > "${VERSION_FILE}" || echo "unknown" > "${VERSION_FILE}"
  ensure_service_template
  ok "Installed: ${BIN_PATH} (version: $(cat "${VERSION_FILE}"))"
}

cmd_update(){
  require_root
  need_cmd systemctl awk grep
  local installed latest
  installed="$(cat "${VERSION_FILE}" 2>/dev/null || echo "none")"
  latest="$(get_latest_version || echo "unknown")"

  if [[ "${installed}" == "${latest}" && "${installed}" != "none" && "${installed}" != "unknown" ]]; then
    ok "Already up to date: ${installed}"
    return
  fi

  info "Updating from ${installed} -> ${latest}"
  mapfile -t running_units < <(systemctl list-units --type=service --state=active --no-legend \
    | awk '{print $1}' | grep "^${SERVICE_PREFIX}@.*\.service$" || true)

  for u in "${running_units[@]:-}"; do
    systemctl stop "${u}" || true
  done

  cmd_download

  for u in "${running_units[@]:-}"; do
    systemctl start "${u}" || true
  done

  ok "Update complete."
}

